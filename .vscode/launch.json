{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Static Site",
            "type": "pwa-chrome",
            "request": "launch",
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Debug Local Server (:8080)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
